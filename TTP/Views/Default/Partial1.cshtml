@using TTP.Models.Entities
@model List<Blog>
<div class="con-bot">
    @foreach (var item in Model)
    {
        <div class="left">
            <div class="bot-left">
                <img src="@item.BlogImage" style="height:185px" />
            </div>
            <div class="left-text">
                <h4>@(item.Baslik.Length > 40 ? @item.Baslik.Substring(0, 37) + "..." : @item.Baslik)</h4>
                <span class="doller">@item.Tarih.Date.ToShortDateString()</span>
                <p>@(item.Aciklama.Length > 100 ? @item.Aciklama.Substring(0, 100) + "..." : @item.Aciklama)</p>
                <p><a href="/Blog/BlogDetay/@item.ID"><span class="read">Devamını Oku >></span></a></p>
            </div>
        </div>
    }
    @Html.Action("Partial2", "Default")
</div>