@using TTP.Models.Entities
@model List<Blog>

<div class="right">
    @foreach (var item in Model)
    {
        <div class="bot-left">
            <img src="@item.BlogImage"/>
        </div>
        <div class="left-text">
            <h4>@(item.Baslik.Length > 40 ? @item.Baslik.Substring(0, 37) + "..." : @item.Baslik)</h4>
            <span class="doller">@item.Tarih.ToString("dd.mm.yyyy")</span>
            <p>@(item.Aciklama.Length > 100 ? @item.Aciklama.Substring(0, 100) + "..." : @item.Aciklama)</p>
            <p><a href="#"><span class="read">Devamını Oku >></span></a></p>
        </div>
    }
</div>