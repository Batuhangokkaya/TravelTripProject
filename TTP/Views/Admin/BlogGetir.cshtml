@using TTP.Models.Entities
@model Blog
@{
    ViewBag.Title = "BlogGetir";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Blog Güncelleme Sayfası</h2>
@using (Html.BeginForm("BlogGuncelle", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    <label>ID</label>
    @Html.TextBoxFor(x => x.ID, new { @class = "form-control", @readonly = "readonly" })
    <br />
    <label>Başlık</label>
    @Html.TextBoxFor(x => x.Baslik, new { @class = "form-control" })
    <br />
    <label>Tarih</label>
    @Html.TextBoxFor(x => x.Tarih, new { @class = "form-control" })
    /*
    @Html.TextBoxFor(x => x.Tarih, Model.Tarih.ToString("dd.MM.yyyy"), new { @class = "form-control" })
    @Html.TextBoxFor(x => x.Tarih, new { @class = "form-control", type = "date" })
    */
    <br />
    <label>Açıklama</label>
    @Html.TextAreaFor(x => x.Aciklama, 15, 1, new { @class = "form-control" })
    <br />
    <label>Görsel Seç</label>
    @Html.TextBox("BlogImageFile", null, new { type = "file", @class = "form-control" })
    <br />
    <button class="btn btn-success">Blog Güncelle</button>
}